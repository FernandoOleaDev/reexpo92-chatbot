# ── Copia a .env en local; en Railway define estas variables en el panel ────────

# Supabase (el service_role es TODOPODEROSO: NUNCA lo pongas en el cliente/web)
SUPABASE_URL=https://wmygankuaoqqhnqqycvs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Groq (capa de generación). Sin clave, el chat funciona en modo "solo búsqueda".
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

# Panel de administración (login básico). Sin RAG_ADMIN_PASS, el panel se bloquea.
RAG_ADMIN_USER=admin
RAG_ADMIN_PASS=

# Cron de reindexado incremental (HH:MM UTC, vacío = desactivado)
REINDEX_CRON=03:00

# Página de ayuda pública a indexar (opcional)
AYUDA_URL=https://reexpo92.com/ayuda

# Dominios que pueden llamar a /chat desde el navegador (coma-separados)
CORS_ORIGINS=http://localhost:5173,https://reexpo92.com,https://www.reexpo92.com

# Secreto para /embed (uso interno / futuro WebGL-Unity). Vacío = /embed cerrado.
EMBED_SECRET=
